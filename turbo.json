{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				"dist/**"
			],
			"env": [
				"VITE_*",
				"NEXT_PUBLIC_*"
			]
		},
		"lint": {
			"outputs": []
		}
	}
}
