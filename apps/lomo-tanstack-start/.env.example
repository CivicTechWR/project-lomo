# Convex deployment identifier (used by `npx convex dev`, not by app code)
CONVEX_DEPLOYMENT=

# Convex API URL (public, used by ConvexProvider)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex site URL (used by auth server functions)
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Local site URL (used for auth redirects)
VITE_SITE_URL=http://localhost:3001
